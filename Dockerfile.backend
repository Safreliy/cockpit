FROM postgres:16

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends python3 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY tools ./tools
COPY web_cockpit ./web_cockpit

EXPOSE 8088

CMD ["python3", "tools/cockpit_backend.py", "--host", "0.0.0.0", "--port", "8088", "--interval", "2"]
