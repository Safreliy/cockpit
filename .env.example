# If cockpit_backend runs in Docker and whatareyatalkinabout runs on the host,
# use http://host.docker.internal:8000 instead of 127.0.0.1.
AI_AGENT_BASE_URL=http://127.0.0.1:8000
AI_AGENT_USER_ID=00000000-0000-4000-8000-000000000001
AI_AGENT_SOURCE=cockpit

# Optional: use an existing model/MCP from whatareyatalkinabout instead of creating them.
AI_AGENT_MODEL_ID=
AI_AGENT_MCP_IDS=

# Optional: create/register a cockpit MCP by URL in whatareyatalkinabout.
AI_AGENT_MCP_URL=
AI_AGENT_MCP_NAME=cockpit-telemetry

# OpenAI-compatible model config used by whatareyatalkinabout when AI_AGENT_MODEL_ID is empty.
LLM_MODEL=
LLM_BASE_URL=
LLM_API_KEY=
